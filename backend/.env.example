# Copy to backend/.env and adjust. All backend settings use the ASSISTANT_ prefix.
# Defaults are baked into assistant.config.Settings, so this file only needs to
# override what differs on your machine.

# --- Persistence (Postgres on host port 5433, Qdrant on 6333) ---
ASSISTANT_DATABASE_URL=postgresql://assistant:assistant@localhost:5433/assistant
ASSISTANT_QDRANT_URL=http://localhost:6333

# --- LLM (model-agnostic via LangChain provider strings) ---
ASSISTANT_OLLAMA_BASE_URL=http://localhost:11434
ASSISTANT_DEFAULT_MODEL=ollama:glm-5.2:cloud
ASSISTANT_EMBEDDING_MODEL=bge-m3

# --- Claude Code bridge (CC talks to Ollama's Anthropic endpoint, not Anthropic) ---
ASSISTANT_CC_ANTHROPIC_BASE_URL=http://localhost:11434
ASSISTANT_CC_MODEL=glm-5.2:cloud
ASSISTANT_CC_MAX_REVIEW_ITERATIONS=3

# --- API (8000 is taken locally by another app; run on 8011) ---
ASSISTANT_API_HOST=127.0.0.1
ASSISTANT_API_PORT=8011

# --- Markdown vault to watch / auto-ingest (empty = disabled) ---
# Absolute path is safest; the watcher runs with cwd = backend/.
ASSISTANT_VAULT_PATH=C:/Users/martin.krisko/Documents/projects/bitch-stewie/vault

# --- Reference examples store (uploaded diagrams/docs the agent mimics) ---
ASSISTANT_EXAMPLES_PATH=C:/Users/martin.krisko/Documents/projects/bitch-stewie/examples

# --- LangSmith tracing (optional; leave API_KEY blank to disable) ---
# The tracer reads these bare LANGSMITH_* vars; the backend pushes them into
# os.environ at startup so LangChain/LangGraph pick them up. Never commit the key.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bitch-stewie