# docker/.env.example — copy to docker/.env (gitignored) and adjust.
# docker/.env is auto-loaded by `docker compose -f docker-compose.prod.yml`
# when run from this dir. ONLY the vars in the "Overridable" section below
# actually take effect — they back `${VAR:-default}` substitutions in the
# compose file. The "Fixed in compose" section is shown for reference; to
# change one of those you edit docker-compose.prod.yml (or convert its line
# to `${VAR:-default}` and move it up here).

# =========================================================================
# Overridable from docker/.env  (these are read via ${VAR:-default} in compose)
# =========================================================================

# --- Claude Code provider (the delegated worker's LLM) ---
# Default is local Ollama. To use Z.ai (recommended for GLM; no `ollama signin`
# needed), comment the Ollama block and uncomment the Z.ai block.
# CC speaks the Anthropic Messages API, so the base URL MUST be an
# Anthropic-compatible endpoint (Ollama and Z.ai expose one; OpenRouter's
# default /api/v1 is OpenAI-compatible and will NOT work directly).
# Z.ai docs: https://docs.z.ai/scenario-example/develop-tools/claude

# --- Ollama (default) ---
ASSISTANT_CC_ANTHROPIC_BASE_URL=http://ollama:11434
ASSISTANT_CC_ANTHROPIC_AUTH_TOKEN=ollama
ASSISTANT_CC_MODEL=glm-5.2:cloud
ASSISTANT_CC_API_TIMEOUT_MS=3000000

# --- Z.ai ---
# Requires a Z.ai API key. Z.ai auto-maps Claude model names -> GLM, so use a
# Claude name for ASSISTANT_CC_MODEL (e.g. claude-sonnet-4-5 -> GLM-4.7).
# ASSISTANT_CC_ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# ASSISTANT_CC_ANTHROPIC_AUTH_TOKEN=your_zai_api_key
# ASSISTANT_CC_MODEL=claude-sonnet-4-5
# ASSISTANT_CC_API_TIMEOUT_MS=3000000

# --- Projects mount (repo checkouts CC edits; self-rewrite target lives here) ---
# PROJECTS_PATH=/home/deploy/projects

# =========================================================================
# Fixed in docker-compose.prod.yml  (reference only — NOT read from .env)
# =========================================================================
# These are set as literal `environment:` values in the backend & worker
# service blocks and point at the in-stack service hostnames:
#
#   ASSISTANT_DATABASE_URL=postgresql://assistant:assistant@postgres:5432/assistant
#   ASSISTANT_QDRANT_URL=http://qdrant:6333
#   ASSISTANT_OLLAMA_BASE_URL=http://ollama:11434
#   ASSISTANT_CC_PLUGINS_DIR=/opt/cc-plugins/enabled
#   ASSISTANT_API_HOST=0.0.0.0
#
# The orchestrator's own planner model is NOT set in compose, so it falls back
# to the config.py default `ollama:glm-5.2:cloud` (still Ollama — see
# docs/findings/2026-07-10.md §"the other half"). To point the planner at Z.ai
# too, add `ASSISTANT_DEFAULT_MODEL` to the compose environment block and
# provide the key (separate change).

# =========================================================================
# Optional: LangSmith tracing (not wired into compose env today)
# =========================================================================
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=assistant